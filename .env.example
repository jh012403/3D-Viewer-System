AI3D_MOCK_MODE=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
WORKER_POLL_INTERVAL_SECONDS=2
LOG_LEVEL=info

# Production-safe default: hide internal model/backend details from API responses.
AI3D_EXPOSE_INTERNAL_MODEL_INFO=false

# Object-only image-to-3D pipeline.
# The reconstruction stage is locked to the official TRELLIS.2 runtime helper.
# Object selection may prepare an object-only image before this point, but the
# TRELLIS.2 runtime repo and generation settings should remain untouched.
AI3D_TRELLIS_DIRECT_INPUT=true
AI3D_SKIP_MULTIVIEW_FOR_DIRECT_RECON=true
AI3D_IMAGE_QUALITY_MODE=high_quality
IMAGE_RECON_HEAD=trellis

# Optional mesh export converter. Required for FBX and future DCC-oriented
# export presets. Leave empty if `blender` is already on PATH.
BLENDER_BIN=

# Text-guided object cutout runtime.
# Keep this in a separate env from ai3d-mvp and trellis2 to avoid dependency
# collisions. Authenticate with `hf auth login` instead of committing tokens.
SAM3_CMD="conda run -n sam3 python"
# Leave empty to auto-detect `./.runtime/sam3` inside the repository.
SAM3_REPO_DIR=
SAM3_MODEL_ID=facebook/sam3
SAM3_DEVICE=cuda
SAM3_CONFIDENCE_THRESHOLD=0.5
SAM3_FALLBACK_CONFIDENCE_THRESHOLD=0.25
SAM3_TEXT_PROMPT_EXPANSION=true
SAM3_TEXT_PROMPT_ALIAS_LIMIT=12
SAM3_MERGE_MODE=best
SAM3_HF_TOKEN=
SAM3_HF_HOME=
SAM3_PYTHONPATH=

# FastVLM semantic metadata runtime.
# The service appends pipelines/image_to_3d/runtime_helpers/fastvlm_extract.py and runtime args.
# First run downloads apple/FastVLM-0.5B into the Hugging Face cache.
FASTVLM_CMD="conda run -n trellis2 python"
FASTVLM_MODEL_ID=apple/FastVLM-0.5B
FASTVLM_MODEL_NAME=FastVLM
FASTVLM_DEVICE=cuda
FASTVLM_DTYPE=float16
FASTVLM_MAX_NEW_TOKENS=512
FASTVLM_TIMEOUT_SEC=900
FASTVLM_REVISION=
FASTVLM_TEMPERATURE=0.0
FASTVLM_TOP_P=1.0
FASTVLM_NUM_BEAMS=1
# Legacy escape hatch: if set, this command replaces FASTVLM_CMD/helper and must print JSON.
FASTVLM_METADATA_CMD=

# TRELLIS.2 reconstruction runtime.
# Command must be a Python prefix; the service appends runtime helper script/args.
# Leave empty to auto-detect `./.runtime/TRELLIS.2` inside the repository.
TRELLIS_REPO_DIR=
TRELLIS_CMD="conda run -n trellis2 python"
TRELLIS_MODEL_PATH=microsoft/TRELLIS.2-4B
TRELLIS_DEVICE=cuda
TRELLIS_RESOLUTION=1024
TRELLIS_SEED=0
TRELLIS_RANDOMIZE_SEED=true
TRELLIS_DECIMATION_TARGET=500000
TRELLIS_TEXTURE_SIZE=2048
TRELLIS_SS_STEPS=12
TRELLIS_SHAPE_STEPS=12
TRELLIS_TEX_STEPS=12
TRELLIS_MESH_SIMPLIFY_FACES=16777216
TRELLIS_LOW_VRAM_MODE=true
TRELLIS_OOM_RETRY_ENABLED=true
TRELLIS_OOM_RETRY_RESOLUTION=512
TRELLIS_STRICT_OFFICIAL_MODE=true
TRELLIS_REQUIRE_CLEAN_REPO=true
TRELLIS_EXTRA_ARGS=

# Runtime cache root for heavy model/helper stacks.
AI3D_RUNTIME_CACHE_ROOT=/tmp/ai3d_cache
